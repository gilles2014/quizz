<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz Inglês Técnico - SEDUC/PI</title>
    <style>
        :root {
            --primary: #2563eb;
            --success: #22c55e;
            --error: #ef4444;
            --bg: #f8fafc;
            --text: #1e293b;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
        }

        #quiz-container {
            background: white;
            width: 100%;
            max-width: 600px;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #f1f5f9;
            padding-bottom: 10px;
        }

        .progress {
            font-weight: bold;
            color: var(--primary);
        }

        .question-text {
            font-size: 1.2rem;
            margin-bottom: 20px;
            line-height: 1.5;
        }

        .options-container {
            display: grid;
            gap: 12px;
        }

        .option-btn {
            padding: 15px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            background: none;
            cursor: pointer;
            text-align: left;
            font-size: 1rem;
            transition: all 0.2s;
        }

        .option-btn:hover:not([disabled]) {
            border-color: var(--primary);
            background-color: #eff6ff;
        }

        .option-btn.correct {
            background-color: var(--success);
            color: white;
            border-color: var(--success);
        }

        .option-btn.wrong {
            background-color: var(--error);
            color: white;
            border-color: var(--error);
        }

        #feedback {
            margin-top: 20px;
            padding: 15px;
            border-radius: 8px;
            display: none;
            background: #f1f5f9;
            font-size: 0.95rem;
        }

        .controls {
            margin-top: 25px;
            display: flex;
            gap: 10px;
        }

        button.primary-btn {
            flex: 1;
            padding: 15px;
            border: none;
            border-radius: 8px;
            background: var(--primary);
            color: white;
            font-weight: bold;
            cursor: pointer;
            font-size: 1rem;
        }

        button.primary-btn:disabled {
            background: #cbd5e1;
            cursor: not-allowed;
        }

        .result-screen {
            text-align: center;
        }

        .share-btn {
            background: #000 !important;
        }
    </style>
</head>
<body>

<div id="quiz-container">
    <div id="game-ui">
        <div class="header">
            <span class="progress" id="question-number">Questão 1/20</span>
            <span id="score-display">Acertos: 0</span>
        </div>
        
        <div class="question-text" id="question-text">Carregando questão...</div>
        
        <div class="options-container" id="options">
            </div>

        <div id="feedback"></div>

        <div class="controls">
            <button class="primary-btn" id="next-btn" onclick="nextQuestion()" disabled>Avançar</button>
        </div>
    </div>

    <div id="result-ui" class="result-screen" style="display: none;">
        <h2>🎉 Quiz Finalizado!</h2>
        <p id="final-score" style="font-size: 1.5rem;"></p>
        <div class="controls">
            <button class="primary-btn" onclick="location.reload()">Reiniciar</button>
            <button class="primary-btn share-btn" onclick="shareResult()">Compartilhar Resultado</button>
        </div>
    </div>
</div>

<script>
    const questions = [
        {
            q: "Leia o trecho: 'Cloud computing allows users to store and access data over the internet instead of on a local hard drive.' De acordo com o texto, qual a função da computação em nuvem?",
            options: ["Aumentar a velocidade do processador local.", "Armazenar e acessar dados via internet.", "Substituir a necessidade de conexão wi-fi.", "Formatar o disco rígido do computador."],
            correct: 1,
            exp: "O texto afirma explicitamente que o armazenamento ocorre 'over the internet' (pela internet)."
        },
        {
            q: "Complete a lacuna: 'The developer needs to ________ the code to fix the bugs found during the testing phase.'",
            options: ["Delete", "Debug", "Print", "Purchase"],
            correct: 1,
            exp: "'Debug' é o termo técnico para identificar e remover erros (bugs)."
        },
        {
            q: "Qual das alternativas apresenta apenas gêneros textuais comuns na informática em inglês?",
            options: ["Lyrics, Novels, Poems.", "Manuals, Tutorials, API Documentation.", "Recipes, Letters, Tales.", "Newspapers, Magazines, Comics."],
            correct: 1,
            exp: "Manuais, tutoriais e documentação são gêneros técnicos essenciais."
        },
        {
            q: "No contexto de empreendedorismo digital, o termo 'Startup' geralmente se refere a:",
            options: ["Uma empresa antiga em processo de falência.", "O botão de ligar um servidor.", "Uma empresa jovem com modelo de negócio escalável.", "Um software de edição de planilhas."],
            correct: 2,
            exp: "Startups focam em inovação e modelos escaláveis."
        },
        {
            q: "Ao ler um manual técnico rapidamente para encontrar uma informação específica, você está usando a estratégia de:",
            options: ["Skimming", "Scanning", "Translating", "Brainstorming"],
            correct: 1,
            exp: "Scanning é a leitura rápida para localizar dados específicos."
        },
        {
            q: "O que significa o acrônimo 'FAQ' em sites e aplicativos?",
            options: ["Fast Access Question", "Frequently Asked Questions", "File And Query", "Final Answer Quiz"],
            correct: 1,
            exp: "FAQ significa 'Perguntas Frequentemente Feitas'."
        },
        {
            q: "Complete: 'A ________ is a set of instructions that tells a computer how to perform a specific task.'",
            options: ["Hardware", "Software", "Mousepad", "Screen"],
            correct: 1,
            exp: "Software é o conjunto de instruções lógicas."
        },
        {
            q: "Na frase: 'The system is down for maintenance', a expressão 'down' indica que o sistema está:",
            options: ["Funcionando perfeitamente.", "Sendo baixado pelo usuário.", "Indisponível ou fora do ar.", "Atualizando os drivers de som."],
            correct: 2,
            exp: "Em TI, 'down' significa fora de operação."
        },
        {
            q: "Qual o termo em inglês para o componente físico que é o 'cérebro' do computador?",
            options: ["Storage", "Display", "CPU (Central Processing Unit)", "Power Supply"],
            correct: 2,
            exp: "A CPU processa as instruções principais."
        },
        {
            q: "O termo 'User-friendly' descreve um sistema que é:",
            options: ["Caro e complexo.", "Fácil de usar e intuitivo.", "Restrito a programadores.", "Incompatível com dispositivos móveis."],
            correct: 1,
            exp: "'User-friendly' significa amigável ao usuário."
        },
        {
            q: "Analise: 'Phishing is a cyber attack that uses disguised email as a weapon.' O 'Phishing' é caracterizado por:",
            options: ["Aumentar a velocidade da internet.", "Um ataque que usa e-mails falsos para enganar usuários.", "Um software de edição de fotos.", "Uma técnica de organização de pastas."],
            correct: 1,
            exp: "Phishing usa iscas (e-mails disfarçados) para roubar dados."
        },
        {
            q: "Complete: 'Before leaving, remember to ________ your account to ensure security.'",
            options: ["Log in", "Sign up", "Log out", "Scroll up"],
            correct: 2,
            exp: "'Log out' encerra a sessão com segurança."
        },
        {
            q: "O que é um 'Dicionário Especializado' (Technical Dictionary) na informática?",
            options: ["Um livro com termos gerais de literatura.", "Uma ferramenta que foca em terminologias de uma área específica.", "Um software que traduz gírias de redes sociais.", "Um manual de instruções de montagem de móveis."],
            correct: 1,
            exp: "Foca em vocabulário técnico de um domínio específico."
        },
        {
            q: "Em TI, o termo 'Backup' refere-se a:",
            options: ["Deletar arquivos permanentemente.", "Cópia de segurança de dados.", "Aumentar o brilho da tela.", "Trocar o teclado do computador."],
            correct: 1,
            exp: "Backup é a salvaguarda de informações."
        },
        {
            q: "Leia: 'Open-source software is code that is designed to be publicly accessible.' Qual a principal característica desse software?",
            options: ["O código é secreto e protegido.", "É obrigatório pagar para ver o código.", "O código é acessível publicamente.", "Só funciona em computadores antigos."],
            correct: 2,
            exp: "Código aberto (Open-source) permite acesso público ao código-fonte."
        },
        {
            q: "Qual verbo é usado para descrever o ato de enviar um arquivo do seu computador para a internet?",
            options: ["Download", "Upload", "Install", "Reboot"],
            correct: 1,
            exp: "Upload é o envio de dados do local para a rede."
        },
        {
            q: "No empreendedorismo, o termo 'B2B' (Business to Business) significa:",
            options: ["Venda direta para o consumidor final.", "Venda de produtos entre empresas.", "Troca de funcionários entre setores.", "Um tipo de vírus de computador."],
            correct: 1,
            exp: "Negócios entre empresas (Business to Business)."
        },
        {
            q: "Complete: 'If your computer is freezing constantly, you might need to ________ it.'",
            options: ["Format", "Reboot", "Burn", "Sell"],
            correct: 1,
            exp: "Rebootar (reiniciar) limpa processos travados."
        },
        {
            q: "O termo 'Framework' em programação refere-se a:",
            options: ["Uma moldura de quadro física.", "Um conjunto de ferramentas e bibliotecas pré-definidas.", "O nome de um sistema operacional.", "Uma linguagem de marcação simples."],
            correct: 1,
            exp: "Frameworks oferecem estruturas prontas para acelerar o desenvolvimento."
        },
        {
            q: "Na frase: 'The connection is encrypted', o termo 'encrypted' sugere que os dados estão:",
            options: ["Expostos a qualquer um.", "Protegidos por codificação.", "Lentos e instáveis.", "Sendo impressos em papel."],
            correct: 1,
            exp: "Encryption é o processo de tornar dados ilegíveis para não autorizados."
        }
    ];

    let currentIdx = 0;
    let score = 0;

    function loadQuestion() {
        const qData = questions[currentIdx];
        document.getElementById('question-number').innerText = `Questão ${currentIdx + 1}/${questions.length}`;
        document.getElementById('question-text').innerText = qData.q;
        document.getElementById('feedback').style.display = 'none';
        document.getElementById('next-btn').disabled = true;
        
        const optionsDiv = document.getElementById('options');
        optionsDiv.innerHTML = '';
        
        qData.options.forEach((opt, i) => {
            const btn = document.createElement('button');
            btn.className = 'option-btn';
            btn.innerText = opt;
            btn.onclick = () => checkAnswer(i);
            optionsDiv.appendChild(btn);
        });
    }

    function checkAnswer(selectedIdx) {
        const qData = questions[currentIdx];
        const buttons = document.querySelectorAll('.option-btn');
        
        buttons.forEach(btn => btn.disabled = true);
        
        if(selectedIdx === qData.correct) {
            buttons[selectedIdx].classList.add('correct');
            score++;
            document.getElementById('score-display').innerText = `Acertos: ${score}`;
        } else {
            buttons[selectedIdx].classList.add('wrong');
            buttons[qData.correct].classList.add('correct');
        }

        const feedback = document.getElementById('feedback');
        feedback.style.display = 'block';
        feedback.innerHTML = `<strong>Explicação:</strong> ${qData.exp}`;
        document.getElementById('next-btn').disabled = false;
    }

    function nextQuestion() {
        currentIdx++;
        if(currentIdx < questions.length) {
            loadQuestion();
        } else {
            showResult();
        }
    }

    function showResult() {
        document.getElementById('game-ui').style.display = 'none';
        document.getElementById('result-ui').style.display = 'block';
        document.getElementById('final-score').innerText = `Você acertou ${score} de ${questions.length} questões!`;
    }

    function shareResult() {
        const text = `Fiz o Quiz de Inglês Técnico da SEDUC/PI e acertei ${score}/${questions.length}! Tente você também!`;
        if (navigator.share) {
            navigator.share({ title: 'Resultado do Quiz', text: text, url: window.location.href });
        } else {
            alert("Copiado para a área de transferência: " + text);
        }
    }

    loadQuestion();
</script>

</body>
</html>
